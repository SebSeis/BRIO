@prefix : <https://w3id.org/brio#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dicp: <https://w3id.org/digitalconstruction/0.5/Processes#> .
@prefix ocqa: <https://w3id.org/ocqa#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ocqa-reg: <https://w3id.org/ocqa/regulation#> .
@base <https://w3id.org/brio#> .

<https://w3id.org/brio> rdf:type owl:Ontology ;
                         owl:versionIRI <https://w3id.org/brio/0.1.1> ;
                         dcterms:editor "Patricia Peralta" ,
                                        "Sebastian Seiß" ,
                                        "Yuan Zheng" ;
                         dcterms:title "BrIO"@en ;
                         vann:preferredNamespacePrefix "brio" ;
                         vann:preferredNamespaceUri : ;
                         rdfs:comment "Ontologie für die Planung von Brückenprüfungen und das Management von Brückenprüfungsdaten."@de ,
                                      "Ontology for bridge inspection planning and bridge inspection data management."@en ;
                         rdfs:isDefinedBy : ;
                         rdfs:label "BrIO ontology"@en ,
                                    "BrIO-Ontologie"@de ;
                         owl:versionInfo "0.1.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/editor
dcterms:editor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/brio#hasInspectionType
:hasInspectionType rdf:type owl:ObjectProperty ;
                   rdfs:domain :BridgeComponentInspection ;
                   rdfs:range :BridgeInspectionType ;
                   rdfs:comment "Relates an inspection to its inspection type."@en ,
                                "Verknüpft eine Prüfung mit ihrem Prüfungstyp."@de ;
                   rdfs:label "hat Prüfungstyp"@de .


###  https://w3id.org/brio#hasInspector
:hasInspector rdf:type owl:ObjectProperty ;
              rdfs:domain ocqa:Inspection ;
              rdfs:range ocqa:Inspector ;
              rdfs:comment "Relates an inspection to the responsible inspector."@en ,
                           "Verknüpft eine Prüfung mit dem verantwortlichen Inspektor."@de ;
              rdfs:label "hat Inspektor"@de .


###  https://w3id.org/brio#preceeds
:preceeds rdf:type owl:ObjectProperty ;
          owl:equivalentProperty dicp:precedes ;
          rdfs:domain :PreparatoryMeasure ;
          rdfs:range ocqa:Inspection ;
          rdfs:comment "Deprecated misspelled property IRI. Use dicp:precedes instead."@en ,
                       "Veraltete, falsch geschriebene Eigenschafts-IRI. Verwenden Sie stattdessen dicp:precedes."@de ;
          rdfs:label "preceeds (deprecated)"@en ,
                     "preceeds (veraltet)"@de ;
          rdfs:seeAlso dicp:precedes ;
          owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/digitalconstruction/0.5/Processes#precedes
dicp:precedes rdf:type owl:ObjectProperty ;
              rdfs:domain :PreparatoryMeasure ;
              rdfs:range ocqa:Inspection ;
              rdfs:comment "Relates a preparatory measure to an inspection that it precedes."@en ,
                           "Verknüpft eine vorbereitende Maßnahme mit einer Prüfung, der sie vorausgeht."@de ;
              rdfs:label "geht voraus"@de ,
                         "precedes"@en .


###  https://w3id.org/ocqa#hasActualCharacteristic
ocqa:hasActualCharacteristic rdf:type owl:ObjectProperty ;
                             rdfs:domain ocqa:Characteristic ;
                             rdfs:range ocqa:ActualCharacteristicValue ;
                             rdfs:comment "Relates a characteristic to its observed or measured actual value."@en ,
                                          "Verknüpft ein Merkmal mit seinem beobachteten oder gemessenen Istwert."@de ;
                             rdfs:label "hat tatsächlichen Merkmalswert"@de .


###  https://w3id.org/ocqa#hasAssignedCharacteristicValue
ocqa:hasAssignedCharacteristicValue rdf:type owl:ObjectProperty ;
                                    rdfs:domain ocqa:Characteristic ;
                                    rdfs:range ocqa:AssignedCharacteristicValue ;
                                    rdfs:comment "Relates a characteristic to its assigned reference or target value."@en ,
                                                 "Verknüpft ein Merkmal mit seinem zugewiesenen Referenz- oder Sollwert."@de ;
                                    rdfs:label "hat vorgegebenen Merkmalswert"@de .


###  https://w3id.org/ocqa#hasDocumentation
ocqa:hasDocumentation rdf:type owl:ObjectProperty ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( ocqa:Evaluation
                                                  ocqa:Inspection
                                                )
                                  ] ;
                      rdfs:range :Documentation ;
                      rdfs:comment "Relates an inspection or evaluation to documentation such as images, videos, or external resources."@en ,
                                   "Verknüpft eine Prüfung oder Bewertung mit Dokumentation wie Bildern, Videos oder externen Ressourcen."@de ;
                      rdfs:label "hat Dokumentation"@de .


###  https://w3id.org/ocqa#hasInspCharacteristic
ocqa:hasInspCharacteristic rdf:type owl:ObjectProperty ;
                           rdfs:domain ocqa:Inspection ;
                           rdfs:range ocqa:Characteristic ;
                           rdfs:comment "Relates an inspection to the characteristics that are evaluated in that inspection."@en ,
                                        "Verknüpft eine Prüfung mit den Merkmalen, die in dieser Prüfung bewertet werden."@de ;
                           rdfs:label "hat Prüfungsmerkmal"@de .


###  https://w3id.org/ocqa#hasInspection
ocqa:hasInspection rdf:type owl:ObjectProperty ;
                   rdfs:range ocqa:Inspection ;
                   rdfs:comment "Relates a resource to an inspection."@en ,
                                "Verknüpft eine Ressource mit einer Prüfung."@de ;
                   rdfs:label "hat Prüfung"@de .


###  https://w3id.org/ocqa#hasInspectionEquipment
ocqa:hasInspectionEquipment rdf:type owl:ObjectProperty ;
                            rdfs:domain ocqa:Inspection ;
                            rdfs:range ocqa:InspectionEquipment ;
                            rdfs:comment "Relates an inspection to the equipment used to perform it."@en ,
                                         "Verknüpft eine Prüfung mit der Ausrüstung, die zu ihrer Durchführung verwendet wird."@de ;
                            rdfs:label "hat Prüfungsausrüstung"@de .


###  https://w3id.org/ocqa#hasInspectionProcedure
ocqa:hasInspectionProcedure rdf:type owl:ObjectProperty ;
                            rdfs:domain ocqa:Inspection ;
                            rdfs:range ocqa:InspectionProcedure ;
                            rdfs:comment "Relates an inspection to the procedure applied during the inspection."@en ,
                                         "Verknüpft eine Prüfung mit dem Verfahren, das während der Prüfung angewendet wird."@de ;
                            rdfs:label "hat Prüfungsverfahren"@de .


###  https://w3id.org/ocqa#hasRecord
ocqa:hasRecord rdf:type owl:ObjectProperty ;
               rdfs:domain ocqa:Inspection ;
               rdfs:range ocqa:Evaluation ;
               rdfs:comment "Relates an inspection to an evaluation result that records a finding."@en ,
                            "Verknüpft eine Prüfung mit einem Bewertungsergebnis, das einen Befund dokumentiert."@de ;
               rdfs:label "hat Befund"@de .


###  https://w3id.org/ocqa/regulation#requiredBy
ocqa-reg:requiredBy rdf:type owl:ObjectProperty ;
                    owl:equivalentProperty ocqa-reg:requiredby ;
                    rdfs:domain ocqa:Inspection ;
                    rdfs:range :Regulation ;
                    rdfs:comment "Links an inspection to the regulation that requires or defines it."@en ,
                                 "Verknüpft eine Prüfung mit der Regelung, durch die sie gefordert oder definiert wird."@de ;
                    rdfs:label "erforderlich durch"@de ,
                               "required by"@en .


###  https://w3id.org/ocqa/regulation#requiredby
ocqa-reg:requiredby rdf:type owl:ObjectProperty ;
                    rdfs:domain ocqa:Inspection ;
                    rdfs:range :Regulation ;
                    rdfs:comment "Deprecated property with non-standard casing. Use ocqa-reg:requiredBy instead."@en ,
                                 "Veraltete Eigenschaft mit uneinheitlicher Groß- und Kleinschreibung. Verwenden Sie stattdessen ocqa-reg:requiredBy."@de ;
                    rdfs:label "requiredby (deprecated)"@en ,
                               "requiredby (veraltet)"@de ;
                    rdfs:seeAlso ocqa-reg:requiredBy ;
                    owl:deprecated "true"^^xsd:boolean .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/brio#accessibility
:accessibility rdf:type owl:DatatypeProperty ;
               rdfs:domain :BridgeComponentInspection ;
               rdfs:range xsd:string ;
               rdfs:comment "Qualitative Zugänglichkeit eines Brückenbauteils für die Prüfung, zum Beispiel einfach, eingeschränkt oder komplex."@de ,
                            "Qualitative accessibility of a bridge component for inspection, for example easy, limited, or complex."@en ;
               rdfs:label "Zugänglichkeit"@de .


###  https://w3id.org/brio#damageID
:damageID rdf:type owl:DatatypeProperty ;
          rdfs:domain ocqa:Nonconformity ;
          rdfs:range xsd:string ;
          rdfs:comment "Identifier assigned to a detected nonconformity or damage."@en ,
                       "Kennung, die einer festgestellten Nichtkonformität oder einem Schaden zugeordnet ist."@de ;
          rdfs:label "Schadens-ID"@de .


###  https://w3id.org/brio#description
:description rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "Textual description of a resource."@en ,
                          "Textuelle Beschreibung einer Ressource."@de ;
             rdfs:label "Beschreibung"@de .


###  https://w3id.org/brio#environment
:environment rdf:type owl:DatatypeProperty ;
             rdfs:domain :BridgeComponentInspection ;
             rdfs:range xsd:string ;
             rdfs:comment "Environmental context relevant to the inspection."@en ,
                          "Umgebungskontext, der für die Prüfung relevant ist."@de ;
             rdfs:label "Umgebung"@de .


###  https://w3id.org/brio#equipmentID
:equipmentID rdf:type owl:DatatypeProperty ;
             rdfs:domain ocqa:InspectionEquipment ;
             rdfs:range xsd:string ;
             rdfs:comment "Identifier assigned to a piece of inspection equipment."@en ,
                          "Kennung, die einer Prüfungsausrüstung zugeordnet ist."@de ;
             rdfs:label "Ausrüstungs-ID"@de .


###  https://w3id.org/brio#equipmentName
:equipmentName rdf:type owl:DatatypeProperty ;
               rdfs:domain ocqa:InspectionEquipment ;
               rdfs:range xsd:string ;
               rdfs:comment "Human-readable name of a piece of inspection equipment."@en ,
                            "Menschenlesbarer Name einer Prüfungsausrüstung."@de ;
               rdfs:label "Ausrüstungsname"@de .


###  https://w3id.org/brio#hasDurabilityRating
:hasDurabilityRating rdf:type owl:DatatypeProperty ;
                     rdfs:domain ocqa:Nonconformity ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Numeric rating that expresses the durability impact of a detected nonconformity."@en ,
                                  "Numerische Bewertung, die die Dauerhaftigkeitsauswirkung einer festgestellten Nichtkonformität ausdrückt."@de ;
                     rdfs:label "hat Dauerhaftigkeitsbewertung"@de .


###  https://w3id.org/brio#hasMaxValue
:hasMaxValue rdf:type owl:DatatypeProperty ;
             rdfs:domain ocqa:AssignedCharacteristicValue ;
             rdfs:range xsd:double ;
             rdfs:comment "Maximal zulässiger oder vorgegebener Wert für eine Merkmalswertspezifikation."@de ,
                          "Maximum allowed or assigned value for a characteristic value specification."@en ;
             rdfs:label "hat Maximalwert"@de .


###  https://w3id.org/brio#hasStructuralRating
:hasStructuralRating rdf:type owl:DatatypeProperty ;
                     rdfs:domain ocqa:Nonconformity ;
                     rdfs:range xsd:double ;
                     rdfs:comment "Numeric rating that expresses the structural impact of a detected nonconformity."@en ,
                                  "Numerische Bewertung, die die statische Auswirkung einer festgestellten Nichtkonformität ausdrückt."@de ;
                     rdfs:label "hat Standsicherheitsbewertung"@de .


###  https://w3id.org/brio#hasTrafficSafetyRating
:hasTrafficSafetyRating rdf:type owl:DatatypeProperty ;
                        rdfs:domain ocqa:Nonconformity ;
                        rdfs:range xsd:double ;
                        rdfs:comment "Numeric rating that expresses the traffic-safety impact of a detected nonconformity."@en ,
                                     "Numerische Bewertung, die die Auswirkung einer festgestellten Nichtkonformität auf die Verkehrssicherheit ausdrückt."@de ;
                        rdfs:label "hat Verkehrssicherheitsbewertung"@de .


###  https://w3id.org/brio#hasUnit
:hasUnit rdf:type owl:DatatypeProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( ocqa:ActualCharacteristicValue
                                     ocqa:AssignedCharacteristicValue
                                   )
                     ] ;
         rdfs:range xsd:string ;
         rdfs:comment "Einheit, die mit einem gemessenen oder vorgegebenen Wert verbunden ist."@de ,
                      "Unit associated with a measured or assigned value."@en ;
         rdfs:label "hat Einheit"@de .


###  https://w3id.org/brio#hasValue
:hasValue rdf:type owl:DatatypeProperty ;
          rdfs:domain ocqa:ActualCharacteristicValue ;
          rdfs:range xsd:double ;
          rdfs:comment "Beobachteter numerischer Wert einer Merkmalswertressource."@de ,
                       "Observed numeric value of a characteristic value resource."@en ;
          rdfs:label "hat Wert"@de .


###  https://w3id.org/brio#inspectionFrequency
:inspectionFrequency rdf:type owl:DatatypeProperty ;
                     rdfs:domain :BridgeInspectionType ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Frequency or interval at which an inspection type is normally carried out."@en ,
                                  "Frequency statement for an inspection type. In this version it is represented as a string."@en ,
                                  "Frequenzangabe für einen Prüfungstyp. In dieser Version wird sie als Zeichenkette repräsentiert."@de ,
                                  "Häufigkeit oder Intervall, in dem ein Prüfungstyp normalerweise durchgeführt wird."@de ;
                     rdfs:label "Prüfungshäufigkeit"@de .


###  https://w3id.org/brio#inspectionScope
:inspectionScope rdf:type owl:DatatypeProperty ;
                 rdfs:domain :BridgeInspectionType ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Textual description of the scope of an inspection type."@en ,
                              "Textuelle Beschreibung des Umfangs eines Prüfungstyps."@de ;
                 rdfs:label "Prüfungsumfang"@de .


###  https://w3id.org/brio#quantity
:quantity rdf:type owl:DatatypeProperty ;
          rdfs:domain :BridgeComponentInspection ;
          rdfs:range xsd:string ;
          rdfs:comment "Menge des inspizierten Brückenbauteils, derzeit als Text einschließlich der Einheit dargestellt."@de ,
                       "Quantity of the inspected bridge component, currently represented as text including the unit."@en ,
                       "Quantity inspected of a bridge component (e.g., m, m2)" ;
          rdfs:label "Menge"@de .


###  https://w3id.org/brio#recommendation
:recommendation rdf:type owl:DatatypeProperty ;
                rdfs:domain :BridgeComponentInspection ;
                rdfs:range xsd:string ;
                rdfs:comment "Empfehlung, die aus dem Prüfungsergebnis abgeleitet wird."@de ,
                             "Recommendation derived from the inspection result."@en ,
                             "Recommendations for a bridge component after an inspection" ;
                rdfs:label "Empfehlung"@de .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/brio#AASHTO-Manual
:AASHTO-Manual rdf:type owl:Class ;
               rdfs:subClassOf ocqa-reg:Guideline ;
               rdfs:comment "Class for AASHTO manuals used as bridge inspection guidelines."@en ,
                            "Klasse für AASHTO-Handbücher, die als Richtlinien für die Brückenprüfung verwendet werden."@de ;
               rdfs:label "AASHTO-Handbuch"@de .


###  https://w3id.org/brio#AccessMeasure
:AccessMeasure rdf:type owl:Class ;
               rdfs:subClassOf :PreparatoryMeasure ;
               rdfs:comment "Preparatory measure required to obtain physical access to the inspection object."@en ,
                            "Vorbereitende Maßnahme, die erforderlich ist, um physischen Zugang zum Prüfungsobjekt zu erhalten."@de ;
               rdfs:label "Zugangsmaßnahme"@de .


###  https://w3id.org/brio#BridgeAccessEquipment
:BridgeAccessEquipment rdf:type owl:Class ;
                       rdfs:subClassOf ocqa:InspectionEquipment ;
                       rdfs:comment "Inspection equipment used to access bridge components, for example a basket truck or under-bridge unit."@en ,
                                    "Prüfungsausrüstung, die zum Zugang zu Brückenbauteilen verwendet wird, zum Beispiel ein Hubkorbfahrzeug oder ein Brückenuntersichtgerät."@de ;
                       rdfs:label "Brückenzugangsausrüstung"@de .


###  https://w3id.org/brio#BridgeAttachementInspection
:BridgeAttachementInspection rdf:type owl:Class ;
                             owl:equivalentClass :BridgeAttachmentInspection ;
                             rdfs:subClassOf :Sub-componentInspection ;
                             rdfs:comment "Deprecated misspelled class IRI. Use brio:BridgeAttachmentInspection instead."@en ,
                                          "Veraltete Klasse mit falsch geschriebener IRI. Verwenden Sie stattdessen brio:BridgeAttachmentInspection."@de ;
                             rdfs:label "Prüfung von Brückenanbauteilen (veraltet)"@de ,
                                        "bridge attachment inspection (deprecated)"@en ;
                             rdfs:seeAlso :BridgeAttachmentInspection ;
                             owl:deprecated "true"^^xsd:boolean .


###  https://w3id.org/brio#BridgeAttachmentInspection
:BridgeAttachmentInspection rdf:type owl:Class ;
                            rdfs:subClassOf :Sub-componentInspection ;
                            rdfs:comment "Inspection of attached bridge elements such as mounted devices or accessories."@en ,
                                         "Prüfung von an der Brücke befestigten Elementen wie montierten Geräten oder Zubehör."@de ;
                            rdfs:label "Prüfung von Brückenanbauteilen"@de ,
                                       "bridge attachment inspection"@en .


###  https://w3id.org/brio#BridgeBearingInspection
:BridgeBearingInspection rdf:type owl:Class ;
                         rdfs:subClassOf :Sub-componentInspection ;
                         rdfs:comment "Inspection of bridge bearings."@en ,
                                      "Prüfung von Brückenlagern."@de ;
                         rdfs:label "Lagerprüfung"@de .


###  https://w3id.org/brio#BridgeComponentInspection
:BridgeComponentInspection rdf:type owl:Class ;
                           rdfs:subClassOf ocqa:Inspection ;
                           rdfs:comment "Inspection that targets a bridge component or a specific part of a bridge component."@en ,
                                        "Prüfung, die auf ein Brückenbauteil oder einen spezifischen Teil eines Brückenbauteils gerichtet ist."@de ;
                           rdfs:label "Brückenbauteilprüfung"@de .


###  https://w3id.org/brio#BridgeConcreteComponentInspection
:BridgeConcreteComponentInspection rdf:type owl:Class ;
                                   rdfs:subClassOf :Material-basedInspection ;
                                   rdfs:comment "Inspection of bridge components made of concrete."@en ,
                                                "Prüfung von Brückenbauteilen aus Beton."@de ;
                                   rdfs:label "Prüfung von Betonbauteilen der Brücke"@de .


###  https://w3id.org/brio#BridgeDrainageSystemInspection
:BridgeDrainageSystemInspection rdf:type owl:Class ;
                                rdfs:subClassOf :Sub-componentInspection ;
                                rdfs:comment "Inspection of the bridge drainage system."@en ,
                                             "Prüfung des Entwässerungssystems einer Brücke."@de ;
                                rdfs:label "Entwässerungssystemprüfung"@de .


###  https://w3id.org/brio#BridgeFoundationInspection
:BridgeFoundationInspection rdf:type owl:Class ;
                            rdfs:subClassOf :Sub-componentInspection ;
                            rdfs:comment "Inspection of bridge foundation elements."@en ,
                                         "Prüfung von Gründungselementen einer Brücke."@de ;
                            rdfs:label "Gründungsprüfung"@de .


###  https://w3id.org/brio#BridgeInspectionEquipment
:BridgeInspectionEquipment rdf:type owl:Class ;
                           rdfs:subClassOf ocqa:InspectionEquipment ;
                           rdfs:comment "Inspection equipment specifically used for bridge inspection tasks."@en ,
                                        "Prüfungsausrüstung, die speziell für Aufgaben der Brückenprüfung verwendet wird."@de ;
                           rdfs:label "Brückenprüfungsausrüstung"@de .


###  https://w3id.org/brio#BridgeInspectionType
:BridgeInspectionType rdf:type owl:Class ;
                      rdfs:comment "Typ oder Kategorie einer Brückenprüfung, zum Beispiel Regelprüfung oder eingehende Prüfung."@de ,
                                   "Type or category of a bridge inspection, for example routine or in-depth inspection."@en ;
                      rdfs:label "Brückenprüfungstyp"@de .


###  https://w3id.org/brio#BridgeJointInspection
:BridgeJointInspection rdf:type owl:Class ;
                       rdfs:subClassOf :Sub-componentInspection ;
                       rdfs:comment "Inspection of bridge joints."@en ,
                                    "Prüfung von Brückenfugen."@de ;
                       rdfs:label "Fugenprüfung"@de .


###  https://w3id.org/brio#BridgeMasonryComponentInspection
:BridgeMasonryComponentInspection rdf:type owl:Class ;
                                  rdfs:subClassOf :Material-basedInspection ;
                                  rdfs:comment "Inspection of bridge components made of masonry."@en ,
                                               "Prüfung von Brückenbauteilen aus Mauerwerk."@de ;
                                  rdfs:label "Prüfung von Mauerwerksbauteilen der Brücke"@de .


###  https://w3id.org/brio#BridgeRailingSystemInspection
:BridgeRailingSystemInspection rdf:type owl:Class ;
                               rdfs:subClassOf :Sub-componentInspection ;
                               rdfs:comment "Inspection of bridge railing systems."@en ,
                                            "Prüfung von Geländersystemen einer Brücke."@de ;
                               rdfs:label "Geländersystemprüfung"@de .


###  https://w3id.org/brio#BridgeSteelCoatingInspection
:BridgeSteelCoatingInspection rdf:type owl:Class ;
                              rdfs:subClassOf :Sub-componentInspection ;
                              rdfs:comment "Inspection of coatings on steel bridge components."@en ,
                                           "Prüfung von Beschichtungen auf Stahlbauteilen der Brücke."@de ;
                              rdfs:label "Beschichtungsprüfung von Stahlbauteilen"@de .


###  https://w3id.org/brio#BridgeSteelStructureInspection
:BridgeSteelStructureInspection rdf:type owl:Class ;
                                rdfs:subClassOf :Material-basedInspection ;
                                rdfs:comment "Inspection of steel bridge structures or steel bridge components."@en ,
                                             "Prüfung von Stahltragwerken oder Stahlbauteilen einer Brücke."@de ;
                                rdfs:label "Stahlbauwerksprüfung"@de .


###  https://w3id.org/brio#BridgeTimberStructureInspection
:BridgeTimberStructureInspection rdf:type owl:Class ;
                                 rdfs:subClassOf :Material-basedInspection ;
                                 rdfs:comment "Inspection of timber bridge structures or timber bridge components."@en ,
                                              "Prüfung von Holztragwerken oder Holzbauteilen einer Brücke."@de ;
                                 rdfs:label "Holzbauwerksprüfung"@de .


###  https://w3id.org/brio#BridgeWearingSurfaceInspection
:BridgeWearingSurfaceInspection rdf:type owl:Class ;
                                rdfs:subClassOf :Sub-componentInspection ;
                                rdfs:comment "Inspection of the bridge wearing surface."@en ,
                                             "Prüfung der Fahrbahnoberfläche einer Brücke."@de ;
                                rdfs:label "Fahrbahnoberflächenprüfung"@de .


###  https://w3id.org/brio#DestructiveTestingEquipment
:DestructiveTestingEquipment rdf:type owl:Class ;
                             rdfs:subClassOf ocqa:InspectionEquipment ;
                             rdfs:comment "Inspection equipment used for destructive testing methods."@en ,
                                          "Prüfungsausrüstung für Verfahren der zerstörenden Prüfung."@de ;
                             rdfs:label "Ausrüstung für zerstörende Prüfung"@de .


###  https://w3id.org/brio#Documentation
:Documentation rdf:type owl:Class ;
               rdfs:comment "Documentation resource created or used during an inspection or evaluation."@en ,
                            "Dokumentationsressource, die während einer Prüfung oder Bewertung erstellt oder verwendet wird."@de ;
               rdfs:label "Dokumentation"@de .


###  https://w3id.org/brio#Material-basedInspection
:Material-basedInspection rdf:type owl:Class ;
