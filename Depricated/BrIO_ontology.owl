#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/chl3331/ontologies/2026/2/bridge_inspection#hasInspectionType
bridge_inspection:hasInspectionType rdf:type owl:ObjectProperty ;
                                    rdfs:domain bridge_inspection:BridgeComponentInspection ;
                                    rdfs:range bridge_inspection:BridgeInspectionType .


###  http://www.semanticweb.org/chl3331/ontologies/2026/2/bridge_inspection#hasInspector
